# ─────────────────────────────────────────────────────────────────────────────
# cc-switcher — API key template
# ─────────────────────────────────────────────────────────────────────────────
# cc-switcher reads provider keys from environment variables. You only need to
# set the ones for providers you actually use — leave the rest blank/commented.
#
# HOW TO USE THIS FILE
#   bash/zsh:  cp .env.example ~/.cc-switcher.env
#              # fill in your keys, then add this line to ~/.bashrc or ~/.zshrc:
#              [ -f ~/.cc-switcher.env ] && source ~/.cc-switcher.env
#
#   PowerShell: this file uses bash `export` syntax. For PowerShell, put the
#              equivalent in your $PROFILE instead, e.g.:
#              $env:OPENROUTER_API_KEY = "sk-or-v1-..."
#
# ⚠️  NEVER commit your real keys. This .example file is safe to commit; a filled-in
#     `.env` / `~/.cc-switcher.env` is NOT (`.env` is already gitignored).
#     See docs/api-key-safety.md before you start.
#
# Verify everything with:  cc-doctor
# ─────────────────────────────────────────────────────────────────────────────


# ── OpenRouter ───────────────────────────────────────────────────────────────
# ⭐ START HERE. One key powers nine provider commands (plus the generic cc-openrouter):
#    cc-glm  cc-gemini  cc-grok  cc-kimi  cc-mimo  cc-minimax-or  cc-qwen
#    cc-nemotron (free)  cc-owl (free)  + cc-openrouter <model>
# Get a key: https://openrouter.ai/settings/keys   (format: sk-or-v1-...)
# Add ≥$10 credits: https://openrouter.ai/settings/credits  (lifts free limit to 1000/day)
export OPENROUTER_API_KEY=""

# ── DeepSeek (direct) ────────────────────────────────────────────────────────
# Powers: cc-deepseek   (cheapest serious pay-per-token coding, 1M context)
# Sign up: https://platform.deepseek.com/sign_up   (format: sk-...)
export DEEPSEEK_API_KEY=""

# ── MiniMax (direct) ─────────────────────────────────────────────────────────
# Powers: cc-minimax    (1M context; PAYG sk-... or token-plan sk-cp... key)
# Sign up: https://platform.minimax.io   ·  Token Plan: .../docs/token-plan/claude-code
export MINIMAX_API_KEY=""

# ── Z.AI / GLM (direct) ──────────────────────────────────────────────────────
# Powers: cc-zai-glm51  (GLM-5.2; or just use cc-glm via OpenRouter)
# Get a key: https://z.ai/manage-apikey/apikey-list  ·  Plans: https://z.ai/subscribe
export ZAI_API_KEY=""

# ── Xiaomi MiMo (direct, token-plan SGP) ─────────────────────────────────────
# Powers: cc-xiaomi     (1M flagship; or use cc-mimo via OpenRouter to skip Xiaomi acct)
# Sign up: https://platform.xiaomimimo.com   (PAYG sk-... or token-plan tp-... key)
export XIAOMI_API_KEY=""

# ── Moonshot / Kimi (direct, optional) ───────────────────────────────────────
# Only needed if you call Kimi directly instead of via cc-kimi (OpenRouter).
# Sign up: https://platform.moonshot.ai   (format: sk-...)
export KIMI_API_KEY=""

# ── NVIDIA NIM (free tier) ───────────────────────────────────────────────────
# Powers: cc-nvidia     (free, rate-limited)
# Get a key: https://build.nvidia.com/settings/api-keys   (format: nvapi-...)
export NVIDIA_API_KEY=""

# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# Powers: cc-ollama-glm  cc-ollama-minimax   (free tier + paid plans)
# Get a key: https://ollama.com/settings/keys
export OLLAMA_API_KEY=""

# ── OpenCode Go ──────────────────────────────────────────────────────────────
# Powers: cc-opencode  cc-opencode-minimax   ($10/mo flat plan)
# Sign up: https://opencode.ai/auth
export OPENCODE_GO_API_KEY=""

# ── OpenAI Codex ─────────────────────────────────────────────────────────────
# Powers: cc-codex — uses OAuth, NOT an API key. No variable to set here:
#   run `cc-codex-login` once (browser device flow). Needs a ChatGPT Plus/Pro plan.


# ── Optional behaviour toggles ───────────────────────────────────────────────
# CC_BANNER: banner verbosity — full (default) | compact | minimal
# export CC_BANNER="compact"
#
# CC_YOLO=1: launch every cc-* command with --dangerously-skip-permissions.
# Leave OFF unless you know what that means. (You can also append --yolo per-command.)
# export CC_YOLO=1
